		<script>
			// PP动画在首页和关于我之间的滚动插值
			const ppEl = document.getElementById("pp-anim") as HTMLElement;
			const scrollContainer = document.body;

			// 首页状态（CSS 变量的初始值，单位为 vh/vw 百分比）
			const startTop = 59; // vh 百分比
			const startLeft = 37; // vw 百分比
			const startWidth = 95; // vw 百分比

			// 关于我页面的目标状态（根据需要调整）用于调整PP动画位置和大小
			const endTop = 48; // vh 百分比
			const endLeft = 45; // vw 百分比
			const endWidth = 130; // vw 百分比

			function lerp(a: number, b: number, t: number): number {
				return a + (b - a) * t;
			}

			function updatePP() {
				const scrollTop = scrollContainer.scrollTop;
				const vh = window.innerHeight;

				// t: 从首页到关于我的滚动进度 (0 ~ 1)
				// scrollTop = 0 时在首页，scrollTop = vh 时完全到达关于我
				const t = Math.max(0, Math.min(1, scrollTop / vh));

				// 超过第2页（scrollTop > 2 * vh）则淡出隐藏
				const fadeStart = 1.0; // 从关于我页底部开始淡出
				const fadeEnd = 1.5; // 到作品集页中间完全消失
				const fadeT = scrollTop / vh;
				let opacity = 1;
				if (fadeT > fadeStart) {
					opacity = Math.max(
						0,
						1 - (fadeT - fadeStart) / (fadeEnd - fadeStart)
					);
				}

				// 插值计算当前值
				const curTop = lerp(startTop, endTop, t);
				const curLeft = lerp(startLeft, endLeft, t);
				const curWidth = lerp(startWidth, endWidth, t);

				ppEl.style.top = curTop + "vh";
				ppEl.style.left = curLeft + "vw";
				ppEl.style.width = curWidth + "vw";
				ppEl.style.opacity = String(opacity);
				ppEl.style.display = opacity <= 0 ? "none" : "block";
			}

			// ===== 区段2 手机入场动画 =====
			const phoneEl = document.querySelector(
				".phone-container"
			) as HTMLElement;

			// 获取 CSS 变量的辅助函数
			function getV(name: string): number {
				const val = getComputedStyle(document.documentElement)
					.getPropertyValue(name)
					.trim();
				return parseFloat(val);
			}

			function updatePhone() {
				const scrollTop = scrollContainer.scrollTop;
				const vh = window.innerHeight;

				// 实时从 CSS 读取最新值
				const sW = getV("--phone-start-width");
				const sT = getV("--phone-start-top");
				const sL = getV("--phone-start-left");

				const eW = getV("--phone-end-width");
				const eT = getV("--phone-end-top");
				const eL = getV("--phone-end-left");

				// t: 从首页到关于我的滚动进度 (0 ~ 1)
				const t = Math.max(0, Math.min(1, scrollTop / vh));

				// 手机在关于我页面完全可见 (t=1)，继续滚动到第3页时淡出
				const fadeStart = 1.0;
				const fadeEnd = 1.5;
				const fadeT = scrollTop / vh;
				let phoneOpacity = t;
				if (fadeT > fadeStart) {
					phoneOpacity = Math.max(
						0,
						1 - (fadeT - fadeStart) / (fadeEnd - fadeStart)
					);
				}

				// 插值计算当前值
				const curPhoneTop = lerp(sT, eT, t);
				const curPhoneLeft = lerp(sL, eL, t);
				const curPhoneWidth = lerp(sW, eW, t);

				// 使用 % 重新赋值
				phoneEl.style.top = curPhoneTop + "%";
				phoneEl.style.left = curPhoneLeft + "%";
				phoneEl.style.width = curPhoneWidth + "%";
				phoneEl.style.transform = "translateY(-50%)";
				phoneEl.style.opacity = String(phoneOpacity);

				if (phoneOpacity <= 0) {
					phoneEl.style.display = "none";
					phoneEl.classList.remove("visible");
				} else {
					phoneEl.style.display = "block";
					if (t >= 0.95) {
						phoneEl.classList.add("visible");
					} else {
						phoneEl.classList.remove("visible");
					}
				}
			}

			// 初始化
			updatePP();
			updatePhone();

			// ===== 向下滚动提示：滚动后隐藏 =====
			const scrollHint = document.getElementById("scroll-hint");
			function updateScrollHint() {
				if (!scrollHint) return;
				if (scrollContainer.scrollTop > 100) {
					scrollHint.classList.add("hidden");
				} else {
					scrollHint.classList.remove("hidden");
				}
			}

			// ===== 区段2 聊天动画逻辑 =====
			const aboutSection = document.getElementById("about");
			const chatBox = document.getElementById("chat-box");
			const typingIndicator = document.getElementById("typing-indicator");

			// 监听子元素（row）动画，将当前正在发送的消息滚动到视口中
			if (chatBox) {
				const rows = chatBox.querySelectorAll(".chat-row");
				rows.forEach((row) => {
					// 动画开始时，将当前 row 滚动到可见区域
					row.addEventListener("animationstart", () => {
						setTimeout(() => {
							(row as HTMLElement).scrollIntoView({
								behavior: "smooth",
								block: "nearest",
							});
						}, 10);
					});
				});
			}

			// 使用 IntersectionObserver 监听 "关于我" 区段是否进入视口
			const observerOptions = {
				root: scrollContainer, // 在 body 滚动
				threshold: 0.5, // 当 50% 的区域进入视口时触发
			};

			let animationHasRun = false;
			let typingHideTimeout: any;

			const aboutObserver = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					// 当滚动到该区域，且动画需要被重置/触发
					if (entry.isIntersecting) {
						if (typingHideTimeout) clearTimeout(typingHideTimeout);

						// 每次进入都重新播放动画
						chatBox?.classList.remove("active");

						// 重置为正在输入状态
						if (typingIndicator) {
							typingIndicator.innerHTML =
								'对方正在输入<span class="typing-dots"><span>.</span><span>.</span><span>.</span></span>';
							typingIndicator.classList.remove("hidden");
						}

						// 1. 每次重新触发时，先滚动到顶端
						if (chatBox) chatBox.scrollTop = 0;

						// 2. 强制重绘，确保动画可以重新触发
						void chatBox?.offsetWidth;

						chatBox?.classList.add("active");

						// 对方正在输入消失的时间：等最后一条消息发送完毕后替换为名字
						typingHideTimeout = setTimeout(() => {
							if (typingIndicator) {
								typingIndicator.innerHTML = "张润芃PP";
							}
						}, 14000);
					} else {
						// 离开视口时重置
						chatBox?.classList.remove("active");
						if (typingIndicator) {
							typingIndicator.innerHTML =
								'对方正在输入<span class="typing-dots"><span>.</span><span>.</span><span>.</span></span>';
							typingIndicator.classList.remove("hidden");
						}
						if (chatBox) chatBox.scrollTop = 0;
						if (typingHideTimeout) clearTimeout(typingHideTimeout);
					}
				});
			}, observerOptions);

			if (aboutSection) {
				aboutObserver.observe(aboutSection);
			}

			// 脚下光可见性控制
			const portfolioSection = document.getElementById("portfolio");
			let glowVisible = false;
			let glowShowTimeout: any = null;
			let portfolioFirstPlay = false; // 标记视频是否已在区段3首次播放

			function setGlowVisible(visible: boolean) {
				glowVisible = visible;
				const allGlows = document.querySelectorAll(".animal-glow");
				allGlows.forEach((el) => {
					(el as HTMLElement).style.visibility = visible
						? "visible"
						: "hidden";
				});
			}

			function updateGlowVisibility() {
				const scrollTop = scrollContainer.scrollTop;
				const vh = window.innerHeight;
				// 作品集是第3个区段 (index=2)，scrollTop 接近 2*vh 时可见
				const portfolioStart = 2 * vh;
				const isInPortfolio =
					scrollTop >= portfolioStart - vh * 0.3 &&
					scrollTop <= portfolioStart + vh * 0.3;

				if (isInPortfolio && !glowVisible) {
					// 进入作品集：延迟1秒后显示
					if (!glowShowTimeout) {
						glowShowTimeout = setTimeout(() => {
							setGlowVisible(true);
							glowShowTimeout = null;
						}, 500);
					}
					// 首次进入区段3时播放视频
					if (!portfolioFirstPlay) {
						portfolioFirstPlay = true;
						const vid = document.getElementById(
							"portfolio-vid"
						) as HTMLVideoElement;
						if (vid && vid.src) {
							vid.currentTime = 0;
							vid.play().catch(() => {
								vid.muted = true;
								vid.play();
							});
						}
					}
				} else if (!isInPortfolio) {
					// 离开作品集：立即隐藏，并取消未执行的延迟
					if (glowShowTimeout) {
						clearTimeout(glowShowTimeout);
						glowShowTimeout = null;
					}
					if (glowVisible) {
						setGlowVisible(false);
					}
					// 离开区段3时暂停视频，下次回来重新播放
					if (portfolioFirstPlay) {
						portfolioFirstPlay = false;
						const vid = document.getElementById(
							"portfolio-vid"
						) as HTMLVideoElement;
						if (vid) {
							vid.pause();
							vid.currentTime = 0;
						}
					}
				}
			}

			// 监听滚动 (PP动画 + 手机动画 + 脚下光)
			scrollContainer.addEventListener(
				"scroll",
				() => {
					requestAnimationFrame(() => {
						updatePP();
						updatePhone();
						updateGlowVisibility();
						updateScrollHint();
					});
				},
				{ passive: true }
			);

			// 监听窗口大小变化
			window.addEventListener("resize", () => {
				updatePP();
				updatePhone();
			});

			// 初始化脚下光可见性（默认隐藏，因为首页不在作品集区段）
			updateGlowVisibility();

			// ===== 区段3：作品集交互逻辑 =====
			const animalBtns = document.querySelectorAll(".animal-btn");
			const portfolioImg = document.getElementById(
				"portfolio-img"
			) as HTMLImageElement;
			const portfolioVid = document.getElementById(
				"portfolio-vid"
			) as HTMLVideoElement;
			const portfolioTitle = document.getElementById(
				"portfolio-title"
			) as HTMLElement;
			const portfolioDesc = document.getElementById(
				"portfolio-desc"
			) as HTMLElement;
			const portfolioDisplay = document.getElementById(
				"portfolio-display"
			) as HTMLElement;

			// 模拟的作品集数据 (支持图片或视频)
			const portfolioData = [
				{
					title: "创意策划：《9102新闻独播》",
					desc: `<div style="margin-bottom:8px;"><span class="skill-tag tag-red">团队统筹</span><span class="skill-tag tag-yellow">沉浸式叙事</span><span class="skill-tag tag-green">全链路执行</span></div>
<em>"如果念 PPT 的宣讲是无聊的定式，那就重构一个时空。"</em>
<br/><br/>
<strong>我是如何"造梦"的：</strong><br/>
我用《新闻联播》片头开启 9102 年倒计时。在"高温 80℃、主席访问土星"的荒诞设定下，我将环保数据揉碎成"最后一只哈士奇的葬礼"的脚本。当熟悉的视听遇上末世叙事，观众瞬间进入了我构建的未来。
<br/><br/>
<strong>作为"排演者"的视角：</strong><br/>
在这场 40 人的项目中，我让每个性格不同的伙伴都找到了光芒：心思缜密、性格内向的同学在幕后打磨道具；表达欲旺盛的伙伴各司其职，演活"未来记者"。我既是控场主播，也是伏地做道具的执行者。这种全环节介入让我明白：最好的统筹，是让每个人在最舒服的位置成全一场梦。
<br/><br/>
<a href="https://mp.weixin.qq.com/s/BhEhcpeIFMPTe8JfCwKsbA" target="_blank" rel="noopener" style="color:#f9c007;text-decoration:underline;">📖 查看公众号原文</a>`,
					type: "video",
					src: "https://videosofpp.oss-cn-hongkong.aliyuncs.com/images/%E4%BD%9C%E5%93%811.webm",
				},
				{
					title: "跨越屏幕的告别：《Happiness》视觉叙事",
					desc: `<div style="margin-bottom:8px;"><span class="skill-tag tag-red">内容洞察</span><span class="skill-tag tag-yellow">情感共鸣策划</span><span class="skill-tag tag-green">视听蒙太奇</span></div>
<em>"在物理隔离的时代，用影像重连情感。"</em>
<br/><br/>
<strong>背景：</strong><br/>
那是疫情期间给班主任的最后一次英语演讲。隔着屏幕，我想给这段师生缘分画一个有仪式感的句号。
<br/><br/>
<strong>创意点：</strong><br/>
灵感来自漫画书《Happiness》。我发现书中那些虚构的幸福，在组员们琐碎的生活里都有对应。我收集了大家的幸福瞬间，配上每个人读诗的声音，把现实和漫画重叠在一起。我独自剪辑了这段视频，没有高大上的特效，只有治愈的轻音乐和最真诚的独白。
<br/><br/>
<strong>最动人的瞬间：</strong><br/>
视频播完，屏幕那头的老师流泪了。这让我笃信：内容策划真正的穿透力，不在于技术多复杂，而在于你捕捉到了多少真心。`,
					type: "video",
					src: "https://videosofpp.oss-cn-hongkong.aliyuncs.com/images/%E4%BD%9C%E5%93%812.webm",
				},
				{
					title: "听得见的环保：MV《Utopia 2100》",
					desc: `<div style="margin-bottom:8px;"><span class="skill-tag tag-red">全能音乐策划</span><span class="skill-tag tag-yellow">通感表达</span><span class="skill-tag tag-green">创意落地</span></div>
<em>"把深刻的议题，藏进每一帧旋律与音轨里。"</em>
<br/><br/>
<strong>初衷：</strong><br/>
谁说科普只能看文字？作为一个敲了 14 年打击乐的人，我更想让环保"动听"起来。我为既有画面定制了整套听觉系统，探索环保议题的感性传播路径。
<br/><br/>
<strong>我是怎么做的：</strong><br/>
我深度参与编曲构思（GarageBand），独立完成全曲 Vocal 录制，通过声音的力度与音色赋予画面叙事灵魂。
<br/><br/>
<strong>成果：</strong><br/>
最终产出的 MV 证明了我既能天马行空地想，也能脚踏实地把旋律和画面一帧帧磨出来。`,
					type: "video",
					src: "https://videosofpp.oss-cn-hongkong.aliyuncs.com/images/%E4%BD%9C%E5%93%813.webm",
				},
				{
					title: '跨越文化的纽带：学院IP"熊猫与黑脸羊"',
					desc: `<div style="margin-bottom:8px;"><span class="skill-tag tag-red">IP孵化</span><span class="skill-tag tag-yellow">视觉策略</span><span class="skill-tag tag-green">社群运营</span></div>
<em>"不仅是画一个吉祥物，更是构筑一种社群归属感。"</em>
<br/><br/>
在中外合作办学的跨文化环境下，我们需要一个视觉符号作为情感连接的锚点。
<br/><br/>
<strong>孵化过程：</strong><br/>
我策划并孵化了学院IP：代表中国的熊猫和代表爱尔兰的黑脸羊。它们不是高高在上的图腾，而是出现在展板、海报和各种物料里的"亲善大使"。
<br/><br/>
<strong>意外的惊喜：</strong><br/>
本以为这只是一个阶段性的任务，没想到直到我毕业后，它们依然是学院各处宣传里的"传家宝"。它留下的不仅是设计，更是一种文化认同的积淀。`,
					type: "video",
					src: "https://videosofpp.oss-cn-hongkong.aliyuncs.com/images/%E4%BD%9C%E5%93%814.webm",
					muted: true,
				},
			];

			// 更新中央展示区的内容
			function updatePortfolioContent(index: number) {
				const data = portfolioData[index];

				// 淡出动画效果
				portfolioDisplay.style.opacity = "0";

				setTimeout(() => {
					// 更新文字
					portfolioTitle.innerText = data.title;
					portfolioDesc.innerHTML = data.desc;

					// 更新媒体
					if (data.type === "video") {
						portfolioImg.style.display = "none";
						portfolioVid.style.display = "block";
						portfolioVid.src = data.src;
						portfolioVid.loop = true;
						portfolioVid.muted = data.muted || false;
						portfolioVid.volume = data.muted ? 0 : 0.5;
						portfolioVid.play().catch(() => {
							// 浏览器可能阻止有声自动播放，先静音播放再提示用户点击取消静音
							portfolioVid.muted = true;
							portfolioVid.play();
						});
					} else {
						portfolioVid.style.display = "none";
						// 暂停视频播放
						portfolioVid.pause();
						portfolioImg.style.display = "block";
						portfolioImg.src = data.src;
					}

					// 淡入
					portfolioDisplay.style.opacity = "1";
				}, 300); // 对应 CSS 中 0.3s 的 transition
			}

			// 初始化作品集内容（只设置文字和视频源，不自动播放）
			function initPortfolioContent(index: number) {
				const data = portfolioData[index];
				portfolioTitle.innerText = data.title;
				portfolioDesc.innerHTML = data.desc;
				if (data.type === "video") {
					portfolioImg.style.display = "none";
					portfolioVid.style.display = "block";
					portfolioVid.src = data.src;
					portfolioVid.loop = true;
					portfolioVid.muted = data.muted || false;
					portfolioVid.volume = data.muted ? 0 : 0.5;
					// 不调用 play()，等滚动到区段3时再播放
				} else {
					portfolioVid.style.display = "none";
					portfolioImg.style.display = "block";
					portfolioImg.src = data.src;
				}
				portfolioDisplay.style.opacity = "1";
			}

			// 更新小动物按钮的活跃状态和“点击它”提示
			// 脚下光元素
			const glowEls = [
				document.getElementById("glow-1"),
				document.getElementById("glow-2"),
				document.getElementById("glow-3"),
				document.getElementById("glow-4"),
			];

			function updateActiveAnimal(activeIndex: number) {
				animalBtns.forEach((btn, idx) => {
					btn.classList.remove("active", "hint-active");

					// 设置当前激活的动物
					if (idx === activeIndex) {
						btn.classList.add("active");
					}

					// 设置提示的动物（上一个，反向引导：4→3→2→1）
					const nextIndex =
						(activeIndex - 1 + animalBtns.length) %
						animalBtns.length;
					if (idx === nextIndex) {
						btn.classList.add("hint-active");
					}
				});

				// 更新脚下光显隐
				glowEls.forEach((el, idx) => {
					if (!el) return;
					if (idx === activeIndex) {
						el.classList.add("active");
					} else {
						el.classList.remove("active");
					}
				});
			}

			// 绑定点击事件
			animalBtns.forEach((btn) => {
				btn.addEventListener("click", () => {
					const index = parseInt(
						btn.getAttribute("data-index") || "0",
						10
					);
					updateActiveAnimal(index);
					updatePortfolioContent(index);
				});
			});

			// 初始化状态 (默认选中第四个，反向展示，但不自动播放视频)
			updateActiveAnimal(3);
			initPortfolioContent(3);

			// ===== 区段4：一键复制功能 =====
			const copyBtns = document.querySelectorAll(".copy-btn");
			copyBtns.forEach((btn) => {
				btn.addEventListener("click", async () => {
					const text = btn.getAttribute("data-copy") || "";
					try {
						await navigator.clipboard.writeText(text);
					} catch {
						// fallback
						const ta = document.createElement("textarea");
						ta.value = text;
						ta.style.position = "fixed";
						ta.style.opacity = "0";
						document.body.appendChild(ta);
						ta.select();
						document.execCommand("copy");
						document.body.removeChild(ta);
					}
					// 显示"已复制"提示
					const toast = btn.parentElement?.querySelector(
						".copy-toast"
					) as HTMLElement;
					if (toast) {
						toast.classList.add("show");
						setTimeout(() => toast.classList.remove("show"), 1500);
					}
				});
			});

			// ===== BGM 喇叭控制逻辑 =====
			const bgmAudio = document.getElementById(
				"bgm-audio"
			) as HTMLAudioElement;
			const bgmBtn = document.getElementById("bgm-toggle") as HTMLElement;
			let bgmUserEnabled = false; // 用户是否手动开启了BGM

			// 点击切换BGM
			bgmBtn.addEventListener("click", () => {
				if (bgmUserEnabled) {
					// 关闭
					bgmUserEnabled = false;
					bgmAudio.pause();
					bgmBtn.innerHTML =
						'<svg viewBox="0 0 24 24" fill="none" stroke="#f4e6b3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>';
					bgmBtn.classList.remove("playing");
				} else {
					// 开启
					bgmUserEnabled = true;
					bgmBtn.innerHTML =
						'<svg viewBox="0 0 24 24" fill="none" stroke="#f4e6b3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>';
					bgmBtn.classList.add("playing");
					// 检查是否有视频在播放，没有才播放
					if (!isAnyVideoPlaying()) {
						bgmAudio.play().catch(() => {});
					}
				}
			});

			// 检测是否有非静音视频正在播放
			function isAnyVideoPlaying(): boolean {
				const videos = document.querySelectorAll("video");
				for (const v of videos) {
					if (!v.paused && !v.muted && v.volume > 0) {
						return true;
					}
				}
				return false;
			}

			// 轮询检测视频播放状态，控制BGM暂停/恢复
			setInterval(() => {
				if (!bgmUserEnabled) return;
				if (isAnyVideoPlaying()) {
					// 有视频在播，暂停BGM
					if (!bgmAudio.paused) {
						bgmAudio.pause();
					}
				} else {
					// 没有视频在播，恢复BGM
					if (bgmAudio.paused) {
						bgmAudio.play().catch(() => {});
					}
				}
			}, 500);
		</script>
	</body>
</html>
