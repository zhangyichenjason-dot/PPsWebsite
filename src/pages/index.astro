<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>PP's Portfolio</title>
		<style is:global>
			:root {
				/* 统一控制所有图片的展示尺寸 —— 修改这里即可一起调整 */
				--img-width: 100%; /* 从 100vw 改为 100% 以适应父容器 */
				--img-height: 100%; /* 从 100vh 改为 100% 以适应父容器 */

				/* hero 视频尺寸和位置 */
				--video-width: 40%; /* 从 40vw 改为 40% 随背景容器缩放 */
				--video-top: 50%;
				--video-left: 52%;

				/* PP动画尺寸和位置 */
				--pp-width: 95vw;
				--pp-top: 59%;
				--pp-left: 37%;

				/* 区段2：关于我 - 手机入场动效控制 */
				/* 结束状态 (目标位置) */
				--phone-end-width: 25%;
				--phone-end-top: 50%;
				--phone-end-left: 46.5%;

				/* 开始状态 (左下角) */
				--phone-start-width: 0%;
				--phone-start-top: 77%;
				--phone-start-left: 18.5%;

				/* ------------------------------------- */
				/* 👑 这里是专门控制“对方正在输入...”的参数 */
				/* ------------------------------------- */
				/* 1. 垂直位置（距离手机顶部的百分比） */
				--typing-text-top: 9.3%;

				/* 2. 文字大小 */
				--typing-text-size: 1.3vw;

				/* 3. 文字颜色 */
				--typing-text-color: #000;

				/* 4. （微调用）水平方向的细微偏移，默认 -50% 是绝对居中。
				   如果你觉得偏左或偏右，可以改成 -48% 或 -52% 来微调 */
				--typing-text-offset-x: -50%;

				/* 5. 小圆点动画的起始位置调整 (如果觉得点点靠上或太靠下) */
				--typing-dots-margin-left: 2px;
				--click-hint-x-offset: -8px; /* 所有“点击它”提示的整体水平微调（负值向左，正值向右） */
				/* ------------------------------------- */

				/* ===== 小动物导航：各自的宽高和间距 ===== */
				/* 整体位置偏移（负值向左/向上，正值向右/向下） */
				--animals-nav-x-offset: -35px;
				--animals-nav-y-offset: -60px;
				/* 间距（负值 = 重叠） */
				--animal-spacing: 0px;

				/* 小动物 1 */
				--animal1-width: 220px;
				--animal1-height: 220px;
				--animal1-hint-x-offset: -25px;

				/* 小动物 2 */
				--animal2-width: 200px;
				--animal2-height: 200px;

				/* 小动物 3 */
				--animal3-width: 230px;
				--animal3-height: 230px;
				--animal3-y-offset: 10px;
				--animal3-hint-y-offset: -25px; /* 小动物 3 提示文字的垂直微调 */
				--animal3-hint-x-offset: -20px; /* 小动物 3 提示文字的水平微调 */

				/* 小动物 4 */
				--animal4-width: 330px;
				--animal4-height: 330px;
				--animal4-x-offset: -30px;
				--animal4-y-offset: 40px; /* 小动物 4 的垂直微调（正值向下，负值向上） */
				--animal4-hint-y-offset: 35px; /* 小动物 4 提示文字的垂直微调 */
				/* ========================================= */
			}

			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			html {
				width: 100%;
				height: 100%;
				overflow: hidden;
				background: #000;
			}

			body {
				width: 100%;
				height: 100%;
				overflow-y: auto;
				scroll-snap-type: y mandatory;
				background: #000;
			}

			/* ========== 公共固定层（各自独立，不包裹在同一容器中） ========== */
			.shared-layer {
				position: fixed;
				top: 0;
				left: 0;
				width: 100vw;
				height: 100vh;
				pointer-events: none;
			}

			.shared-layer img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}

			.shared-bg {
				z-index: 1;
			}

			.shared-fg {
				z-index: 50;
			}

			.shared-filter {
				z-index: 60;
				mix-blend-mode: multiply;
			}

			/* ========== 区段通用样式 ========== */
			.section {
				position: relative;
				z-index: 10;
				width: 100vw;
				height: 100vh;
				scroll-snap-align: start;
				scroll-snap-stop: always;
			}

			/* ========== 首页区段内容 ========== */
			.home-content {
				position: absolute;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
				width: 100vw;
				height: calc(100vw * 900 / 1600);
			}
			@media (max-aspect-ratio: 1600/900) {
				.home-content {
					width: calc(100vh * 1600 / 900);
					height: 100vh;
				}
			}

			.layer {
				position: absolute;
				top: 0;
				left: 0;
				width: var(--img-width);
				height: var(--img-height);
			}

			.layer img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}

			.layer-2 {
				z-index: 3;
			}
			.layer-3 {
				z-index: 4;
			}
			.layer-title {
				z-index: 5;
			}

			.pp-animation-wrapper {
				position: fixed;
				z-index: 15;
				pointer-events: none;
				will-change: top, left, width, opacity;
				transform: translate(-50%, -50%);
			}
			.pp-animation-wrapper img {
				width: 100%;
				height: auto;
				display: block;
			}

			.hero-video-wrapper {
				position: absolute;
				top: var(--video-top);
				left: var(--video-left);
				transform: translate(-50%, -50%);
				z-index: 2;
				width: var(--video-width);
			}

			.hero-video-wrapper video {
				width: 100%;
				height: auto;
				display: block;
			}

			/* ========== 其他区段内容样式 ========== */
			.section-content {
				position: relative;
				z-index: 10;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				/* 不再让内容强行超出一屏（100vh）而跑到下一个区域去 */
				width: 100%;
				height: 100vh;
				max-height: 100vh;
				overflow-y: auto;
				padding: 4rem;
				color: #fff;
			}
			/* 隐藏默认滚动条，自定义细滚动条（解决因防溢出而出现的滚动条丑的问题） */
			.section-content::-webkit-scrollbar {
				width: 4px;
				height: 4px;
			}
			.section-content::-webkit-scrollbar-track {
				background: transparent;
			}
			.section-content::-webkit-scrollbar-thumb {
				background: rgba(255, 255, 255, 0.2);
				border-radius: 4px;
			}

			.section-content .content-card {
				background: rgba(0, 0, 0, 0.55);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border: 1px solid rgba(255, 255, 255, 0.1);
				border-radius: 24px;
				padding: 3rem 4rem;
				max-width: 700px;
				width: 100%;
				text-align: center;
			}

			.section-content h2 {
				font-family: "Helvetica Neue", Arial, sans-serif;
				font-size: 2.5rem;
				font-weight: 700;
				margin-bottom: 1.5rem;
				letter-spacing: 0.05em;
			}

			.section-content p {
				font-family: "Helvetica Neue", Arial, sans-serif;
				font-size: 1.1rem;
				line-height: 1.8;
				opacity: 0.85;
			}

			/* ========== 区段2 手机及打字动画样式 ========== */
			.phone-container {
				position: fixed;
				z-index: 20;
				pointer-events: none;
				will-change: top, left, width, opacity;
				/* JS 会控制 top, left, width, opacity */
			}

			.phone-container img {
				width: 100%;
				height: auto;
				display: block;
			}

			/* 手机可见时允许交互 */
			.phone-container.visible {
				pointer-events: auto;
			}

			/* ============================================= */
			/* “对方正在输入...”及“张润芃PP”的文字外框控制区 */
			/* ============================================= */
			.phone-text {
				position: absolute;
				/* 读取你在最顶部设置的参数 */
				top: var(--typing-text-top);
				left: 50%;
				transform: translateX(var(--typing-text-offset-x));
				font-size: var(--typing-text-size);
				color: var(--typing-text-color);

				font-family: inherit;
				font-weight: bold;
				display: flex;
				justify-content: center;
				align-items: center;
				white-space: nowrap;
				transition: opacity 0.3s;
			}

			.phone-text.hidden {
				opacity: 0;
				pointer-events: none;
			}

			/* 打字动画的小圆点容器 */
			.typing-dots {
				display: inline-flex;
				align-items: flex-end;
				margin-left: var(--typing-dots-margin-left);
			}

			/* 单个跳动的小圆点 */
			.typing-dots span {
				display: inline-block;
				animation: bounce 1.4s infinite ease-in-out both;
			}

			.typing-dots span:nth-child(1) {
				animation-delay: -0.32s;
			}

			.typing-dots span:nth-child(2) {
				animation-delay: -0.16s;
			}

			@keyframes bounce {
				0%,
				80%,
				100% {
					transform: translateY(0);
				}
				40% {
					transform: translateY(-5px);
				}
			}

			/* ========== 微信聊天界面样式 ========== */
			.chat-container {
				position: absolute;
				top: 15%; /* 调整距离手机顶部的距离，避开刘海/额头 */
				left: 8%;
				right: 8%;
				bottom: 10%; /* 留出底部空间 */
				max-height: 60vh; /* 防止非常狭窄或偏平的屏幕下聊天内容超出可视区域 */
				overflow-y: auto;
				overflow-x: hidden;
				display: flex;
				flex-direction: column;
				gap: 12px;
				padding-right: 4px; /* 为滚动条留点空间 */

				/* 初始状态隐藏，等待动画触发 */
				opacity: 0;
				pointer-events: none;
				transition: opacity 0.3s;
			}

			.chat-container.active {
				opacity: 1;
				pointer-events: auto;
			}

			/* 隐藏默认滚动条，自定义细滚动条 */
			.chat-container::-webkit-scrollbar {
				width: 4px;
			}
			.chat-container::-webkit-scrollbar-track {
				background: transparent;
			}
			.chat-container::-webkit-scrollbar-thumb {
				background: rgba(0, 0, 0, 0.2);
				border-radius: 4px;
			}

			.chat-row {
				display: flex;
				align-items: flex-start;
				gap: 10px;
				opacity: 0;
				transform: translateY(20px);
				width: 100%;
			}
			.chat-row.left {
				justify-content: flex-start;
			}
			.chat-row.right {
				justify-content: flex-end;
			}

			.avatar {
				width: 35px;
				height: 35px;
				background-color: transparent;
				border-radius: 4px;
				flex-shrink: 0;
			}
			.avatar img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 4px;
				display: block;
			}

			.chat-bubble {
				max-width: 75%;
				padding: 10px 14px;
				border-radius: 8px;
				font-size: 0.9rem; /* 可根据实际手机显示大小微调 */
				line-height: 1.5;
				word-break: break-word;
				position: relative;
				color: #333;
			}

			/* 气泡小尾巴通用样式 */
			.chat-bubble::before {
				content: "";
				position: absolute;
				top: 10px;
				border-width: 6px;
			}

			/* 左侧白色气泡（我发的） */
			.bubble-left {
				background-color: #fff;
				border-top-left-radius: 2px;
			}
			.bubble-left::before {
				left: -12px;
				border-style: solid;
				border-color: transparent #fff transparent transparent;
			}
			.bubble-left::after {
				display: none;
			}

			/* 右侧绿色气泡（对方发的） */
			.bubble-right {
				background-color: #95ec69; /* 微信绿 */
				border-top-right-radius: 2px;
			}
			.bubble-right::before {
				right: -12px;
				border-style: solid;
				border-color: transparent transparent transparent #95ec69;
			}
			.bubble-right::after {
				display: none;
			}

			/* 气泡出现动画 */
			@keyframes slideUpFade {
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			/* 当容器激活时，内的row依次播放动画 */
			.chat-container.active .chat-row {
				animation: slideUpFade 0.6s ease-out forwards;
			}

			/* 延迟设置（加长间隔） */
			.chat-container.active .chat-row:nth-child(1) {
				animation-delay: 0.5s;
			}
			.chat-container.active .chat-row:nth-child(2) {
				animation-delay: 1s;
			}
			.chat-container.active .chat-row:nth-child(3) {
				animation-delay: 4s;
			}
			.chat-container.active .chat-row:nth-child(4) {
				animation-delay: 8s;
			}
			.chat-container.active .chat-row:nth-child(5) {
				animation-delay: 12s;
			}
			.chat-container.active .chat-row:nth-child(6) {
				animation-delay: 14s;
			}

			/* ========== 向下滚动提示 ========== */
			.scroll-hint {
				position: absolute;
				bottom: 56px;
				left: 50%;
				transform: translateX(-50%);
				z-index: 40;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 4px;
				opacity: 0;
				animation: scrollHintFadeIn 1.5s 1s forwards;
				transition: opacity 0.5s ease;
				pointer-events: none;
			}
			.scroll-hint.hidden {
				opacity: 0 !important;
			}
			.scroll-hint-arrow {
				font-size: 1.4rem;
				color: #f4e6b3;
				animation: scrollBounce 1.8s ease-in-out infinite;
			}
			.scroll-hint-text {
				font-size: 0.75rem;
				color: rgba(244, 230, 179, 0.7);
				letter-spacing: 2px;
			}
			@keyframes scrollHintFadeIn {
				to {
					opacity: 1;
				}
			}
			@keyframes scrollBounce {
				0%,
				100% {
					transform: translateY(0);
				}
				50% {
					transform: translateY(8px);
				}
			}

			/* ========== 区段3 作品集相关样式 ========== */
			.portfolio-container {
				width: 80%;
				max-width: 1200px;
				margin: 0 auto;
				display: flex;
				flex-direction: column;
				gap: 0px;
				align-items: center;
				/* 将定死的很大 padding 改为灵活占比并设置最低限度 */
				padding-top: max(60px, 12vh);
				max-height: 100vh;
				overflow-y: auto;
			}

			/* 顶部的小动物导航排 */
			.animals-nav {
				display: flex;
				justify-content: center;
				align-items: flex-end;
				position: relative;
				left: var(--animals-nav-x-offset);
				top: var(--animals-nav-y-offset);
			}

			.animal-btn {
				position: relative;
				cursor: pointer;
				transition: transform 0.3s ease;
				/* 用 margin 控制间距，支持负值重叠 */
				margin-left: var(--animal-spacing);
			}
			/* 第一个不需要左间距 */
			.animal-btn:first-child {
				margin-left: 0;
			}
			.animal-btn:hover {
				transform: scale(1.05);
				z-index: 5;
			}

			.animal-btn img {
				object-fit: cover;
				border-radius: 0; /* 矩形，不裁成圆 */
				border: none;
				transition: all 0.3s ease;
				opacity: 0.4; /* 默认未选中状态变暗 */
				filter: grayscale(30%);
				display: block;
			}

			/* 每只小动物各自的尺寸 */
			.animal-btn:nth-child(1) img {
				width: var(--animal1-width);
				height: var(--animal1-height);
			}
			.animal-btn:nth-child(1) .click-hint {
				--click-hint-x-offset: var(--animal1-hint-x-offset);
			}

			.animal-btn:nth-child(2) img {
				width: var(--animal2-width);
				height: var(--animal2-height);
			}
			.animal-btn:nth-child(3) img {
				width: var(--animal3-width);
				height: var(--animal3-height);
			}
			.animal-btn:nth-child(3) .click-hint {
				top: var(--animal3-hint-y-offset);
				--click-hint-x-offset: var(--animal3-hint-x-offset);
			}
			.animal-btn:nth-child(3) {
				top: var(--animal3-y-offset);
			}
			.animal-btn:nth-child(4) img {
				width: var(--animal4-width);
				height: var(--animal4-height);
			}
			.animal-btn:nth-child(4) {
				left: var(--animal4-x-offset);
			}
			.animal-btn:nth-child(4) {
				top: var(--animal4-y-offset);
			}
			.animal-btn:nth-child(4) .click-hint {
				top: var(--animal4-hint-y-offset);
			}

			/* 被选中的小动物 */
			.animal-btn.active img {
				opacity: 1;
				filter: grayscale(0%);
			}

			/* 小动物脚下光 */
			.animal-glow {
				position: fixed;
				top: 0;
				left: 0;
				width: 100vw;
				height: 100vh;
				pointer-events: none;
				z-index: 9; /* 在区段内容之下，小动物导航之下 */
				opacity: 0;
				visibility: hidden; /* 默认隐藏，由 JS 在进入作品集区段后控制 */
				transition: opacity 0.4s ease;
			}
			.animal-glow img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.animal-glow.active {
				opacity: 1;
			}

			/* “点击它”跳动提示 */
			.click-hint {
				position: absolute;
				top: -30px; /* 移到上方 */
				left: 50%;
				transform: translateX(calc(-50% + var(--click-hint-x-offset)));
				color: #f4e6b3;
				font-size: 0.8rem;
				font-weight: bold;
				white-space: nowrap;
				background: none; /* 移除背景 */
				padding: 0; /* 移除内边距 */
				pointer-events: none; /* 防止遮挡点击 */
				opacity: 0;
				transition: opacity 0.3s ease;
				animation: floatHint 1.5s infinite ease-in-out;
			}

			/* 只有拥有 hint-active 类的按钮才会显示提示 */
			.animal-btn.hint-active .click-hint {
				opacity: 1;
			}

			@keyframes floatHint {
				0%,
				100% {
					transform: translateX(
							calc(-50% + var(--click-hint-x-offset))
						)
						translateY(0);
				}
				50% {
					transform: translateX(
							calc(-50% + var(--click-hint-x-offset))
						)
						translateY(-8px); /* 向上跳动 */
				}
			}

			/* 下半部分：左右分栏展示 */
			.portfolio-content-split {
				display: flex;
				width: 100%;
				background: rgba(255, 255, 255, 0.1);
				backdrop-filter: blur(10px);
				border-radius: 20px;
				padding: 40px;
				gap: 40px;
				border: 1px solid rgba(255, 255, 255, 0.2);
				min-height: 480px;
				align-items: center;
				transition: opacity 0.3s ease;
			}

			.portfolio-media {
				flex: 1;
				display: flex;
				justify-content: center;
				align-items: center;
				background: rgba(0, 0, 0, 0.3);
				border-radius: 12px;
				padding: 20px;
				min-height: 300px;
			}
			.portfolio-media img,
			.portfolio-media video {
				max-width: 100%;
				max-height: 350px;
				border-radius: 8px;
				object-fit: contain;
			}

			.portfolio-text {
				flex: 1;
				color: #fff;
				display: flex;
				flex-direction: column;
				justify-content: flex-start;
				overflow-y: auto;
				max-height: 400px;
			}
			.portfolio-text h3 {
				font-size: 1.4rem;
				margin-bottom: 12px;
				color: #f0f0f0;
