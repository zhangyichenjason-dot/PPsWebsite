			><svg
				viewBox="0 0 24 24"
				fill="none"
				stroke="#f4e6b3"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"
				></polygon><line x1="23" y1="9" x2="17" y2="15"></line><line
					x1="17"
					y1="9"
					x2="23"
					y2="15"></line>
			</svg>
